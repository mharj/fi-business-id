{
    "name": "mharj-fi-business-id",
    "version": "0.1.2",
    "description": "Finnish Business ID (Y-tunnus) validation and builder",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        "import": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "require": {
            "types": "./dist/index.d.cts",
            "default": "./dist/index.cjs"
        },
        "default": "./dist/index.mjs"
    },
    "scripts": {
        "build": "tsdown src/index.ts --sourcemap --format cjs,esm --dts --clean",
        "prepublishOnly": "npm run build",
        "test": "vitest test --run --no-isolate --coverage",
        "coverage": "vitest test --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
        "lint": "biome check",
        "validate": "tsc --noEmit"
    },
    "repository": "github:mharj/fi-business-id",
    "files": [
        "dist"
    ],
    "keywords": [
        "businessid"
    ],
    "author": "mharj",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/mharj/fi-business-id/issues"
    },
    "homepage": "https://github.com/mharj/fi-business-id#readme",
    "devDependencies": {
        "@biomejs/biome": "2.5.4",
        "@types/node": "^25.9.5",
        "@vitest/coverage-v8": "^4.1.10",
        "c8": "^12.0.0",
        "tsdown": "^0.22.9",
        "typescript": "^7.0.2",
        "vite": "^8.1.5",
        "vitest": "^4.1.10"
    },
    "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e"
}
